          <gridbag top="15" left="10" bottom="2" right="10" weightx="1.0" weighty="0.0"/>
        </constraints>
        <properties>
          <text value="Complete todos los campos del formulario superior con los datos del turista y su dirección."/>
        </properties>
      </component>
      <component id="instructions2" class="javax.swing.JLabel" binding="lblInstruccionesCliente2">
