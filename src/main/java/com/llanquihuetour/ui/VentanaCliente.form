<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.llanquihuetour.ui.VentanaCliente">
  <grid id="27dc6" binding="panelPrincipalCliente" layout-manager="GridBagLayout">
    <constraints>
      <xy x="20" y="20" width="800" height="600"/>
    </constraints>
    <properties>
      <maximumSize width="800" height="600"/>
      <minimumSize width="800" height="600"/>
      <preferredSize width="800" height="600"/>
