                      <grid row="5" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
                      <gridbag top="3" left="3" bottom="3" right="3" weightx="1.0" weighty="0.0"/>
                    </constraints>
                    <properties>
                      <toolTipText value="Ejemplo: PPDD55"/>
                    </properties>
                  </component>
                  <component id="lbl_capacidad" class="javax.swing.JLabel" binding="lblCapacidad">
                    <constraints>
                      <grid row="6" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="4" fill="0" indent="0" use-parent-layout="false"/>
                      <gridbag top="3" left="3" bottom="3" right="3" weightx="0.0" weighty="0.0"/>
                    </constraints>
                    <properties>
